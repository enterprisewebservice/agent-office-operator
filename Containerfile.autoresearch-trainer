# Trainer container for Karpathy-style AutoResearch QLoRA experiments.
#
# Used by Data Science Pipelines steps the operator submits per
# AutoResearchProject experiment cycle. The pod that runs this image
# has its GPU power-capped via an init container before training
# starts (default 250W per GPU; configurable on AutoResearchProject)
# so a runaway experiment can't trip the 4090 node's breaker.
#
# Stack rationale (researched, not guessed):
#   - Base image is the official PyTorch image (pytorch/pytorch on
#     Docker Hub). Picked because MODH's runtime-pytorch image
#     (quay.io/modh/runtime-pytorch-cuda-py312-ubi9) requires auth
#     for non-cluster pulls and Konflux's build pod doesn't carry
#     a MODH pull secret. The official PyTorch image gives the
#     same PyTorch + CUDA + cuDNN stack, just on Debian instead of
#     UBI9 — fine for the kfp pipeline step since we're not
#     shipping it into a regulated cluster path.
#   - training-hub is RHOAI's recommended LLM fine-tuning SDK (Training
#     Hub, GA in OpenShift AI 3.x). Wraps SFT / OSFT / LoRA / QLoRA.
#   - peft + bitsandbytes + accelerate are the standard QLoRA stack;
#     Training Hub depends on them. Listed explicitly so version
#     pinning stays auditable.
#   - deepspeed brings ZeRO-3 + ZeRO-Infinity offload — required to
#     fine-tune anything bigger than ~13B on the cluster's 24GB GPUs.
#   - The lm-evaluation-harness wrapper (TrustyAI LMEvalJob) runs
#     deep benchmarks for kept variants from its own image; this
#     trainer image only needs Training Hub's inline eval (built in).
#
# Note: the `quay-quay-quay-test.apps.salamander.aimlworkbench.com`
# hostname is an OpenShift Route pattern, not three "quay" tokens —
# Quay Operator's route is `quay-quay` in namespace `quay-test`, so the
# rendered route is `quay-quay-quay-test.apps.<cluster>`. Functional;
# the funny name is cosmetic.
# Build-retry note (2026-05-16): two consecutive v0.0.6 builds
# failed at STEP 12 (final LABEL commit) with buildah
# "Digest did not match" while writing the final layered blob —
# transient storage flake, not a code issue. To reduce surface
# area for the flake we slim the image below by dropping
# deepspeed (200-300 MB; only needed for ZeRO-Infinity offload
# which we don't use for granite-8b QLoRA on a 24GB GPU).
FROM pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime

USER 0

# System tools the offload + lm-eval steps occasionally need.
# Debian-based base — apt rather than dnf.
RUN apt-get update -y \
    && apt-get install -y --no-install-recommends \
        git \
        git-lfs \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Pinned tight because the bitsandbytes / transformers / CUDA matrix
# is fragile on this base image. Verified empirically across v0.0.2-5:
#
#   - bitsandbytes==0.43.3 is the last CUDA-12 release. 0.44+ links
#     libnvJitLink.so.13 which doesn't exist in cuda12.4-cudnn9-runtime
#     (we hit "libnvJitLink.so.13: cannot open shared object file" on
#     model load).
#
#   - transformers 4.48+ introduced `validate_bnb_backend_availability`
#     and the new bnb backend API, which requires bnb >=0.44. With our
#     bnb 0.43 pin we hit "Could not import module
#     'validate_bnb_backend_availability'" at bnb_4bit model load.
#     transformers==4.46.3 is the last 4.46 release and the last
#     to use the old (bnb 0.43-compatible) loader path.
#
#   - trl 0.12.x is the first to ship `processing_class=` (we use it)
#     and stable `SFTConfig`. 0.13+ moves fields off TrainingArguments
#     in ways that have broken our run.py.
#
#   - training-hub is intentionally dropped: it hard-floors
#     transformers>=4.55 (even at v0.2.0), which transitively forces
#     bnb 0.44+ and breaks the CUDA-12 matrix. We don't actually
#     import anything from training-hub in run.py — we call
#     transformers + peft + trl + bnb directly. Adding it back at
#     CUDA-13 base time is fine; on CUDA-12 it's a poison pill.
#
#   - deepspeed is intentionally dropped: only useful for ZeRO-3 +
#     ZeRO-Infinity offload (multi-billion-param models that don't
#     fit in GPU + CPU). For granite-8b at 4-bit NF4 + LoRA + grad
#     checkpointing on a single 24GB GPU we use bnb's built-in
#     compute_dtype offload, not deepspeed. Re-add when we want
#     multi-GPU FSDP-QLoRA via Kubeflow Trainer (Phase 5+).
#
# When we move to a CUDA-13 PyTorch base, lift the upper pins on bnb
# and transformers in lockstep and optionally re-add training-hub.
RUN pip install --no-cache-dir \
        'peft>=0.13,<1' \
        'bitsandbytes==0.43.3' \
        'accelerate>=1.0,<2' \
        'transformers==4.46.3' \
        'datasets>=4.0.0,<5' \
        'trl>=0.12,<0.13' \
        'sentencepiece' \
        'safetensors' \
        'pyyaml' \
        'huggingface_hub' \
        'evaluate>=0.4'

# Trainer entrypoint baked in. The operator's Job spec invokes
# `python /opt/autoresearch/run.py` and passes the agent's
# QLoRA config via the AUTORESEARCH_CONFIG env var.
RUN mkdir -p /opt/autoresearch
COPY scripts/autoresearch-trainer/run.py /opt/autoresearch/run.py
RUN chmod -R g=u /opt/autoresearch

WORKDIR /workspace

# OpenShift runs pods under a random non-root UID for security;
# directories the pip wheels installed into need group-write so
# any UID in the root group can read/write. The pytorch base
# image is built around root by default — fix the perms here so
# kfp's UID assignment doesn't break.
RUN chmod -R g=u /opt/conda /workspace
