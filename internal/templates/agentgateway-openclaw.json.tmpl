{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "{{.GatewayToken}}"
    },
    "remote": {
      "token": "{{.GatewayToken}}"
    },
    "controlUi": {
      "allowedOrigins": [{{range $i, $o := .AllowedOrigins}}{{if $i}},{{end}}"{{$o}}"{{end}}]
    },
    "trustedProxies": ["10.128.0.0/14", "10.131.0.0/16", "127.0.0.1", "::1"]
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5.4"
      }
    },
    "list": []
  },
  "bindings": []
}
