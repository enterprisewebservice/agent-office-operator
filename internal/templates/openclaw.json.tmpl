{
  "gateway": {
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "remote": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": [{{range $i, $o := .AllowedOrigins}}{{if $i}},{{end}}"{{$o}}"{{end}}]
    },
    "trustedProxies": ["10.128.0.0/14", "10.131.0.0/16", "127.0.0.1", "::1"]
  },
  "models": {
    "providers": {
      "{{.ProviderName}}": {
        "baseUrl": "{{.BaseURL}}",
        "api": "openai-completions",
        "apiKey": "{{.APIKeyRef}}",
        "models": [{{range $i, $m := .Models}}{{if $i}},{{end}}{"id": "{{$m.ID}}", "name": "{{$m.Name}}"}{{end}}]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "{{.DefaultModel}}"
      }
    }
  }
}
