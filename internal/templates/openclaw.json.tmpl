{
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw"
  },
  "gateway": {
    "port": 18789,
    "auth": {
      "token": "{{.GatewayToken}}"
    },
    "controlUi": {
      "allowedOrigins": [{{range $i, $o := .AllowedOrigins}}{{if $i}},{{end}}"{{$o}}"{{end}}]
    }
  },
  "models": {
    "providers": {
      "{{.ProviderName}}": {
        "baseUrl": "{{.BaseURL}}",
        "api": "openai-completions",
        "apiKey": "{{.APIKeyRef}}",
        "models": [{{range $i, $m := .Models}}{{if $i}},{{end}}{"id": "{{$m.ID}}", "name": "{{$m.Name}}"}{{end}}]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "{{.DefaultModel}}"
      }
    }
  },
  "tools": {
    "allow": ["exec", "group:plugins"]
  },
  "plugins": {
    "enabled": true,
    "entries": {
      "browser": {"enabled": true},
      "openai": {"enabled": true}
    }
  }
}
